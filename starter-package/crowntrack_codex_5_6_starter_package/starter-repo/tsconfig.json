{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "skipLibCheck": true,
    "allowJs": false,
    "paths": {
      "@crowntrack/core": ["packages/core/src/index.ts"],
      "@crowntrack/offline-packs": ["packages/offline-packs/src/index.ts"],
      "@crowntrack/ui": ["packages/ui/src/index.tsx"],
      "@crowntrack/crew-protocol": ["packages/crew-protocol/src/index.ts"],
      "@crowntrack/crewlink": ["packages/crewlink/src/index.ts"],
      "@crowntrack/crew-identity": ["packages/crew-identity/src/index.ts"]
    }
  },
  "include": ["apps/**/*.ts", "apps/**/*.tsx", "packages/**/*.ts", "packages/**/*.tsx", "tests/**/*.ts"]
}
